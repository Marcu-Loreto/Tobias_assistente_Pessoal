OPENAI_API_KEY=suachaveda Openai
#LLM_MODEL=gpt-4.1-mini

GOOGLE_API_KEY=ASuachave Google-Gemini

# Músculo Pesado (Busca Web / Tools / Raciocínio Complexo)
MODEL_OPENAI_STRONG=gpt-4o

# Intermediário Premium (Análise de documentos com ótimo custo)
MODEL_OPENAI_BALANCED=gpt-4.1-mini

# Conversa Geral (Bate-papo denso e explicações teóricas)
MODEL_GOOGLE_BALANCED=gpt-4.1-mini

# Economia de Guerra (Textos minúsculos / "Olá" / "Tchau" / Parsing)
MODEL_GOOGLE_CHEAP=gpt-4o-mini


# ----------------------------------------------------
# 2. Redis - Memória de Curto Prazo
# OBS: No Docker Compose, estas URLs são sobrescritas para apontar pro contêiner interno. 
# Estes valores abaixo servem para rodar no terminal localmente (uv run streamlit run main.py)
# ----------------------------------------------------
REDIS_URL=redis://:myredissecret@localhost:6379/0
REDIS_TTL_SECONDS=3600

# ----------------------------------------------------
# 3. Qdrant - Memória de Longo Prazo / Semântica
# OBS: O Compose também vai sobrescrever a URL caso inicie pelo Docker (`http://qdrant:6333`).
# ----------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=tobias_memory


#tempo

OPENWEATHER_API_KEY=suachave
OPENWEATHER_GEOCODING_URL=https://api.openweathermap.org/geo/1.0/direct
OPENWEATHER_ONECALL_URL=https://api.openweathermap.org/data/3.0/onecall